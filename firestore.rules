// PRODUCTION (locked) Firestore rules — deploy LAST, only AFTER the new client
// (which submits via Cloud Functions) is live. Deploying these while the old
// client is still live would stop score-saving, since the old client writes
// scores directly.
//
// To apply: copy this over firestore.rules, then `firebase deploy --only firestore:rules`.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Scores are written ONLY by Cloud Functions (Admin SDK, which bypasses these
    // rules). Clients may read the leaderboard, but can no longer write scores
    // directly — this is what finally makes scores unforgeable.
    match /scores/{scoreId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Game sessions are issued and consumed by Cloud Functions only.
    match /sessions/{sessionId} {
      allow read, write: if false;
    }

    // Username registry + per-user records: written ONLY by Cloud Functions.
    // Reads are allowed (names are public on the leaderboard anyway).
    match /usernames/{name} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Feedback: any authenticated user may submit; no client reads.
    match /feedback/{document} {
      allow create: if request.auth != null
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
